# ==============================================================
# VX Admin — Environment Configuration
# ==============================================================
# Copy this to .env.local and fill in your values.
# .env.local is gitignored and never committed.
# ==============================================================

# --- Firebase Client SDK (REQUIRED — for Firestore access) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin SDK (REQUIRED — for server-side API routes) ---
# Path to service account JSON file. If not set, auto-discovers:
#   ./service-account.development.json  or
#   ../../service-account.development.json (monorepo root)
FIREBASE_SERVICE_ACCOUNT_PATH=

# --- Cloudflare R2 Storage (REQUIRED — for image URLs) ---
# Public base URL (client-side, used to display images)
NEXT_PUBLIC_R2_PUBLIC_BASE_URL=https://image.lagroups.org

# R2 credentials (server-side only, for upload API)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=coloring-app
R2_PUBLIC_BASE_URL=https://image.lagroups.org

# --- Azure OpenAI (REQUIRED — for AI features) ---
# Your Azure OpenAI resource endpoint
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# API key for Azure OpenAI
AZURE_OPENAI_API_KEY=

# LLM deployment name for text/vision (default: gpt-4o)
AZURE_LLM_DEPLOYMENT_NAME=gpt-4o

# Image generation deployment name (default: gpt-image-2)
AZURE_IMAGE_DEPLOYMENT_NAME=gpt-image-2

# API version (default: 2025-04-01-preview)
OPENAI_API_VERSION=2025-04-01-preview

# --- Image Provider Selection ---
# Options: "azure" (default), "gemini", "vertex", "diaflow"
IMAGE_PROVIDER=vertex

# --- LLM Provider Selection ---
# Options: "azure" (default), "diaflow"
# When not set, uses Azure OpenAI for text/vision
LLM_PROVIDER=

# --- Google Gemini (only if IMAGE_PROVIDER=gemini) ---
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation

# --- Vertex AI (only if IMAGE_PROVIDER=vertex) ---
# GCP project ID (required)
GOOGLE_CLOUD_PROJECT=
# GCP region (default: us-central1)
GOOGLE_CLOUD_REGION=us-central1
# Model name (default: gemini-2.0-flash-preview-image-generation)
VERTEX_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation
# Path to service account JSON (for local dev — on GCP this is auto-detected)
GOOGLE_APPLICATION_CREDENTIALS=

# --- Diaflow (only if IMAGE_PROVIDER=diaflow and/or LLM_PROVIDER=diaflow) ---
# Base API URL (default: https://api.diaflow.io)
DIAFLOW_API_URL=https://api.diaflow.io
# Bearer token for authentication (required)
DIAFLOW_TOKEN=
# Polling interval in seconds (default: 3)
DIAFLOW_POLL_INTERVAL=3
# Max wait time in seconds (default: 300)
DIAFLOW_POLL_TIMEOUT=300
